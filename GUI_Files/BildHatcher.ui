  <property name="styleSheet">
   <string notr="true">QWidget{
background-color: rgb(230,230,230);
}

QGroupBox{
color:  rgb(80, 0, 19);  /* Text color */
font-weight: bold;  /* Bold text */
}

QLabel{
color:  rgb(80, 0, 19);;  /* Text color */
}


/* BUTTON*/

QPushButton {
	background-color: rgb(122,0,28);  /* Background color */
	border: 1px solid rgb(0, 0, 0);
    color: rgb(255, 255, 255);  /* Text color */
    border-radius: 5px;  /* Rounded edges */
	padding: 2px;
}

QPushButton:hover {
    background-color: rgb(142, 0, 38);  /* Background color when hovered */
	color: rgb(245, 245, 245);
    border-color:rgb(40, 40, 40);  /* Border color when hovered */
}

QPushButton:pressed {
   color:  rgb(80, 0, 19);  /* Background color when pressed */
	border-color: rgb(0, 0, 0);
}
QPushButton:clicked {
   background-color: rgb(80,0,19);  /* Background color when pressed */
	border-color:  rgb(0,0, 0);
}

QPushButton:checked {
    background-color: rgb(255,255,255);
	color:  rgb(80, 0, 19);
	border: 2px solid rgb(122, 0, 28);
	font-weight: bold;  /* Bold text */
}

QPushButton:disabled {
    background-color: rgb(180,180, 180);
	border: 1px solid rgb(0, 0,0);
}


/* SPIN BOX*/

QDoubleSpinBox:enabled{
background-color: rgb(255,255,255);
color:  rgb(80, 0, 19);  /* Text color */
border: 1px solid  rgb(122, 0, 28);  /* Border color */
border-radius: 5px;  /* Rounded edges */
padding : 2px;
}
QDoubleSpinBox:disabled{
color: rgb(80, 0, 19);  /* Text color */
border: 1px solid rgb(255,255,255);  /* Border color */
border-radius: 5px;  /* Rounded edges */
padding : 2px;
}

QSpinBox:enabled{
background-color: rgb(255,255,255);
color:  rgb(80, 0, 19);  /* Text color */
border: 1px solid  rgb(122, 0, 28);  /* Border color */
border-radius: 5px;  /* Rounded edges */
padding : 2px;

}
QSpinBox:disabled{
color: rgb(80, 0, 19);  /* Text color */
border: 1px solid rgb(255,255,255);  /* Border color */
border-radius: 5px;  /* Rounded edges */
padding : 2px;
}


/* TEXT EDIT*/

QPlainTextEdit{
background-color: rgb(255,255,255);
border-radius: 5px;  /* Rounded edges */
}


/* LINE EDIT*/

QLineEdit:endabled{
background-color: rgb(255,255,255);
color:  rgb(80, 0, 19);  /* Text color */
border: 1px solid rgb(0,0,0);  /* Border color */
border-radius: 5px;  /* Rounded edges */
padding : 2px;
}

QLineEdit:disabled{
background-color: rgb(230,230,230);
color:  rgb(80, 0, 19);  /* Text color */
border: 1px solid rgb(0,0,0);  /* Border color */
border-radius: 5px;  /* Rounded edges */
padding : 2px;
}


/* COMBOBOX*/

QComboBox{
background-color: rgb(255,255,255);
color:  rgb(80, 0, 19);  /* Text color */
border: 1px solid rgb(0,0,0);  /* Border color */
border-radius: 5px;  /* Rounded edges */
padding : 2px;
}


/* TAB*/

QTabBar::tab {
    color:  rgb(80, 0, 19); 
    border: 1px solid rgb(122,0,28);
    padding: 5px;
    border-top-left-radius: 5px;
    border-top-right-radius: 5px;
	min-width:80px;
}

QTabBar::tab:selected {
    color:  rgb(80, 0, 19); 
    background-color: rgb(255, 255, 255); ;
    font-weight: bold;
	border: 2px solid rgb(122, 0, 28);
}

QTabBar::tab:hover {
    color:  rgb(122, 0, 28); /* Slightly lighter orange */
	background-color: rgb(245, 245, 245); ;
}


/* CHECKBOX*/

QCheckBox {
        spacing: 8 px;
        color: rgb(80, 0, 19);
    }
    
    QCheckBox::indicator {
        width: 14px;
        height: 14px;
        border: 2px solid rgb(122, 0, 28);
        border-radius: 3px;
        background-color: rgb(255, 255, 255);
    }
    
    QCheckBox::indicator:hover {
        border: 2px solid rgb(142, 0, 38);
        background-color: rgb(245, 245, 245);
    }
    
    QCheckBox::indicator:checked {
        background-color: rgb(122, 0, 28);
        border: 2px solid rgb(122, 0, 28);
    }
    
    QCheckBox::indicator:checked:hover {
        background-color: rgb(142, 0, 38);
        border: 2px solid rgb(142, 0, 38);
    }
    
    QCheckBox::indicator:checked:pressed {
        background-color: rgb(80, 0, 19);
        border: 2px solid rgb(80, 0, 19);
    }
    
    QCheckBox:disabled {
        color: rgb(180, 180, 180);
    }
    
    QCheckBox::indicator:disabled {
        background-color: rgb(230, 230, 230);
        border: 2px solid rgb(200, 200, 200);
    }

/* ListWidget*/

QListWidget{
background-color: rgb(255,255,255);  /* Background color */
}




/*STYLE CLASSES*/

/*OutsideFrame*/
QGroupBox[styleClass=&quot;outsideFrame&quot;]{
border: 2px solid rgb(122, 0, 28);
background-color: rgb(240,240,240);  /* Background color */
margin: 0px;
}
QGroupBox[styleClass=&quot;outsideFrame&quot;] QGroupBox{
background-color: rgb(240,240,240);  /* Background color */
}
QGroupBox[styleClass=&quot;outsideFrame&quot;] QLabel{
background-color: rgb(240,240,240);  /* Background color */
}
QGroupBox[styleClass=&quot;outsideFrame&quot;] QSlider{
background-color: rgb(240,240,240);  /* Background color */
}
QGroupBox[styleClass=&quot;outsideFrame&quot;] QCheckBox{
background-color: rgb(240,240,240);  /* Background color */
}

/*InsideFrame*/
QGroupBox[styleClass=&quot;insideFrame&quot;]{
border: 0px solid rgb(0, 0, 0);
padding: 10px;
margin: 0px;
}

/*verticalSubFrame*/
QGroupBox[styleClass=&quot;verticalSubFrame&quot;]{
color:  rgb(80, 0, 19);  /* Text color */
font-weight: normal;  /* Bold text */
font-style: italic;
border: 1px solid rgb(122, 0, 28);
border-left: none;
border-right: none;
border-bottom: none;
margin-top: 8px;
padding-top:5px
}
QGroupBox[styleClass=&quot;verticalSubFrame&quot;]::title {
    /* Tells Qt to position the title in the margin area we created above */
    subcontrol-origin: margin;
	subcontrol-position: top center; 
	padding: 0px 5px;
}


/*MenuButton*/
QPushButton[styleClass=&quot;MenuButton&quot;] {
	background-color: rgb(122,0,28);  /* Background color */
	border: 1px solid rgb(0, 0, 0);
    color: rgb(255, 255, 255);  /* Text color */
	font-size: 14px;
    border-radius: 0px;
	padding: 2px;
}

QPushButton[styleClass=&quot;MenuButton&quot;]::hover {
    background-color: rgb(142, 0, 38);  /* Background color when hovered */
	color: rgb(245, 245, 245);
    border-color:rgb(40, 40, 40);  /* Border color when hovered */
}

QPushButton[styleClass=&quot;MenuButton&quot;]::pressed {
   color:  rgb(80, 0, 19);  /* Background color when pressed */
	border-color: rgb(0, 0, 0);
}
QPushButton[styleClass=&quot;MenuButton&quot;]::clicked {
   background-color: rgb(80,0,19);  /* Background color when pressed */
	border-color:  rgb(0,0, 0);
}

QPushButton[styleClass=&quot;MenuButton&quot;]::checked {
    background-color: rgb(255,255,255);
	color:  rgb(80, 0, 19);
	border: 1px solid rgb(122, 0, 28);
	border-top: none;
	border-left: none;
	border-right: none;
	font-weight: bold;  /* Bold text */
}

QPushButton[styleClass=&quot;MenuButton&quot;]::disabled {
    background-color: rgb(180,180, 180);
	border: 0px solid rgb(0, 0,0);
}</string>
